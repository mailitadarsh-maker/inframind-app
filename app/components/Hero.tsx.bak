'use client';

import { useEffect, useRef, useState } from 'react';

const monitors = [
  { name: 'api.myapp.com', ms: '142ms', uptime: 99, status: 'up' },
  { name: 'dashboard.myapp.com', ms: '89ms', uptime: 100, status: 'up' },
  { name: 'payments.myapp.com', ms: '—', uptime: 60, status: 'down' },
];

const AI_REPORT = [
  { text: '🔴 Incident detected', delay: 0 },
  { text: ' · payments.myapp.com', delay: 400 },
  { text: '\n\n', delay: 700 },
  { text: 'Your payments endpoint returned ', delay: 800 },
  { text: 'HTTP 503', delay: 1100, bold: true },
  { text: ' at 14:32 UTC. ', delay: 1300 },
  { text: 'Root cause: ', delay: 1600 },
  { text: 'database connection pool exhausted', delay: 1800, bold: true },
  { text: ' (max 100 reached).', delay: 2200 },
  { text: '\n\n', delay: 2500 },
  { text: '✅ Fix: restart the pool or increase ', delay: 2600 },
  { text: 'DB_POOL_SIZE', delay: 2900, bold: true },
  { text: ' in your config.', delay: 3100 },
  { text: '\n\n⚡ Estimated customer impact: ', delay: 3400 },
  { text: '~4 min downtime.', delay: 3700, bold: true },
];

const BLOG_POSTS = [
  { tag: 'jewellery', title: '5 Signs Your Gold Investment Is Actually Worth It', date: 'Jun 14', status: 'live' },
  { tag: 'trends', title: 'Dubai Gold Souk vs Online: Which Gets You More?', date: 'Jun 11', status: 'live' },
  { tag: 'seo', title: 'Best Bridal Jewellery Trends 2025…', date: 'just now', status: 'writing' },
];

export default function Hero() {
  const [tick, setTick] = useState(1);
  const [reportChunks, setReportChunks] = useState<{ text: string; bold?: boolean }[]>([]);
  const [paymentsStatus, setPaymentsStatus] = useState<'up' | 'down' | 'warn'>('up');
  const [cycleKey, setCycleKey] = useState(0);
  const [activeTab, setActiveTab] = useState<'monitoring' | 'blog'>('monitoring');
  const [genDot, setGenDot] = useState(true);
  const [ping1, setPing1] = useState(142);
  const [ping2, setPing2] = useState(89);

  useEffect(() => {
    const id = setInterval(() => setTick((t) => (t % 59) + 1), 1000);
    return () => clearInterval(id);
  }, []);

  useEffect(() => {
    const id = setInterval(() => {
      setPing1(Math.floor(Math.random() * 60) + 110);
      setPing2(Math.floor(Math.random() * 30) + 70);
    }, 3000);
    return () => clearInterval(id);
  }, []);

  useEffect(() => {
    const id = setInterval(() => setGenDot((d) => !d), 600);
    return () => clearInterval(id);
  }, []);

  useEffect(() => {
    let timeouts: ReturnType<typeof setTimeout>[] = [];
    const runCycle = () => {
      setPaymentsStatus('up');
      setReportChunks([]);
      timeouts.push(setTimeout(() => setPaymentsStatus('down'), 2500));
      let cumulative = 3200;
      AI_REPORT.forEach((chunk) => {
        timeouts.push(setTimeout(() => {
          setReportChunks((prev) => [...prev, { text: chunk.text, bold: chunk.bold }]);
        }, cumulative + chunk.delay));
      });
      timeouts.push(setTimeout(() => setPaymentsStatus('up'), 10000));
      timeouts.push(setTimeout(() => setCycleKey((k) => k + 1), 13000));
    };
    runCycle();
    return () => timeouts.forEach(clearTimeout);
  }, [cycleKey]);

  const monitorList = monitors.map((m) =>
    m.name === 'payments.myapp.com' ? { ...m, status: paymentsStatus } : m
  );

  const isMonitoring = activeTab === 'monitoring';

  return (
    <section className="relative min-h-screen flex flex-col items-center justify-center pt-24 pb-16 px-6 overflow-hidden">
      {/* Grid */}
      <div
        className="absolute inset-0 pointer-events-none"
        style={{
          backgroundImage:
            'linear-gradient(rgba(255,255,255,0.03) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.03) 1px, transparent 1px)',
          backgroundSize: '48px 48px',
          animation: 'gridDrift 12s linear infinite',
          maskImage: 'radial-gradient(ellipse 80% 60% at 50% 40%, black 20%, transparent 80%)',
          WebkitMaskImage: 'radial-gradient(ellipse 80% 60% at 50% 40%, black 20%, transparent 80%)',
        }}
      />

      {/* Glow — switches color with tab */}
      <div
        className="absolute pointer-events-none transition-all duration-700"
        style={{
          width: 600,
          height: 600,
          top: '20%',
          left: '50%',
          transform: 'translateX(-50%)',
          background: isMonitoring
            ? 'radial-gradient(circle, rgba(29,219,120,0.07) 0%, transparent 70%)'
            : 'radial-gradient(circle, rgba(167,139,250,0.09) 0%, transparent 70%)',
          animation: 'breathe 5s ease-in-out infinite',
        }}
      />

      <div className="relative z-10 max-w-5xl w-full text-center">
        {/* Badge */}
        <div
          className="inline-flex items-center gap-2 px-3.5 py-1.5 rounded-full border border-green-border bg-green-bg text-green text-xs font-medium mb-8"
          style={{ animation: 'fadeUp 0.5s 0.1s ease both', opacity: 0 }}
        >
          <span className="w-1.5 h-1.5 rounded-full bg-green animate-blink" />
          Now in beta — free to start
        </div>

        {/* Headline — swaps with tab */}
        <h1
          className="font-serif text-5xl md:text-6xl lg:text-7xl leading-[1.05] tracking-[-1px] mb-5 transition-all duration-500"
          style={{ animation: 'fadeUp 0.6s 0.2s ease both', opacity: 0 }}
        >
          {isMonitoring ? (
            <>
              Your apps,{' '}
              <em className="text-green not-italic" style={{ animation: 'textPulse 3s ease-in-out infinite' }}>
                always running.
              </em>
              <br />
              Without a full-time dev.
            </>
          ) : (
            <>
              Publish SEO blogs{' '}
              <em className="not-italic" style={{ color: '#a78bfa', animation: 'textPulse 3s ease-in-out infinite' }}>
                for every client,
              </em>
              <br />
              automatically.
            </>
          )}
        </h1>

        {/* Sub */}
        <p
          className="text-text-2 text-base md:text-lg leading-relaxed max-w-xl mx-auto mb-8 font-light transition-all duration-500"
          style={{ animation: 'fadeUp 0.6s 0.35s ease both', opacity: 0 }}
        >
          {isMonitoring
            ? 'InfraMind monitors your apps, scans for problems, and explains everything in plain English — so you never get surprised by downtime again.'
            : 'InfraMind generates AI blog posts, publishes them to your clients' subdomains, and handles all the SEO setup — from one dashboard.'}
        </p>

        {/* Product tabs */}
        <div
          className="inline-flex items-center gap-1 rounded-xl border border-white/[0.08] bg-[#2b3039] p-1 mb-8"
          style={{ animation: 'fadeUp 0.6s 0.45s ease both', opacity: 0 }}
        >
          <button
            onClick={() => setActiveTab('monitoring')}
            className="flex items-center gap-2 px-5 py-2.5 rounded-lg text-sm font-semibold transition-all duration-250"
            style={{
              background: isMonitoring ? '#1ddb78' : 'transparent',
              color: isMonitoring ? '#07090d' : 'rgba(255,255,255,0.4)',
            }}
          >
            <span
              className="w-2 h-2 rounded-full"
              style={{ background: isMonitoring ? '#07090d' : '#1ddb78', opacity: isMonitoring ? 0.6 : 1 }}
            />
            App Monitoring
          </button>
          <button
            onClick={() => setActiveTab('blog')}
            className="flex items-center gap-2 px-5 py-2.5 rounded-lg text-sm font-semibold transition-all duration-250"
            style={{
              background: !isMonitoring ? '#a78bfa' : 'transparent',
              color: !isMonitoring ? '#1a1035' : 'rgba(255,255,255,0.4)',
            }}
          >
            <span
              className="w-2 h-2 rounded-full"
              style={{ background: !isMonitoring ? '#1a1035' : '#a78bfa', opacity: !isMonitoring ? 0.6 : 1 }}
            />
            Blog as a Service
          </button>
        </div>

        {/* CTAs */}
        <div
          className="flex items-center justify-center gap-3 mb-10"
          style={{ animation: 'fadeUp 0.6s 0.5s ease both', opacity: 0 }}
        >
          {isMonitoring ? (
            <>
              <a href="/signup" className="btn btn-primary btn-lg relative overflow-hidden group">
                <span className="relative z-10">Get started free →</span>
                <span className="absolute inset-0 bg-white/0 group-hover:bg-white/10 transition-colors duration-200" />
              </a>
              <a href="#how-it-works" className="btn btn-ghost btn-lg">See how it works</a>
            </>
          ) : (
            <>
              <a
                href="/signup"
                className="btn btn-lg relative overflow-hidden group"
                style={{ background: '#a78bfa', color: '#1a1035', fontWeight: 700 }}
              >
                <span className="relative z-10">Start blog service →</span>
                <span className="absolute inset-0 bg-white/0 group-hover:bg-white/10 transition-colors duration-200" />
              </a>
              <a href="/blog-service" className="btn btn-ghost btn-lg">See how it works</a>
            </>
          )}
        </div>

        {/* Demo panel */}
        <div
          className="relative rounded-xl border overflow-hidden shadow-[0_32px_80px_rgba(0,0,0,0.6)] transition-all duration-500"
          style={{
            animation: 'fadeUp 0.7s 0.65s ease both',
            opacity: 0,
            background: '#2b3039',
            borderColor: isMonitoring ? 'rgba(29,219,120,0.15)' : 'rgba(167,139,250,0.2)',
          }}
        >
          {/* Scan beam */}
          <div className="absolute inset-0 pointer-events-none z-10 overflow-hidden rounded-xl">
            <div
              className="absolute top-0 bottom-0 w-16"
              style={{
                background: isMonitoring
                  ? 'linear-gradient(90deg, transparent, rgba(29,219,120,0.05), transparent)'
                  : 'linear-gradient(90deg, transparent, rgba(167,139,250,0.05), transparent)',
                animation: 'scanBeam 3.5s ease-in-out infinite',
              }}
            />
          </div>

          {/* Window bar */}
          <div className="flex items-center gap-2 px-4 py-3 bg-[#313742] border-b border-white/[0.05]">
            <span className="w-2.5 h-2.5 rounded-full bg-[#FF5F57]" />
            <span className="w-2.5 h-2.5 rounded-full bg-[#FEBC2E]" />
            <span className="w-2.5 h-2.5 rounded-full bg-[#28C840]" />
            <span className="ml-3 text-xs text-text-2 font-mono">
              InfraMind — {isMonitoring ? 'live monitors' : 'blog dashboard'}
            </span>
            <div className="ml-auto flex items-center gap-1.5 text-xs text-text-2 font-mono">
              <span
                className="w-1.5 h-1.5 rounded-full animate-blink"
                style={{ background: isMonitoring ? '#1ddb78' : '#a78bfa' }}
              />
              {isMonitoring ? 'watching' : '3 clients active'}
            </div>
          </div>

          {/* MONITORING PANEL */}
          {isMonitoring && (
            <div className="flex flex-col md:flex-row">
              {/* Left: monitor list */}
              <div className="flex-1 p-4 space-y-2.5 border-b md:border-b-0 md:border-r border-white/[0.05]">
                <div className="text-[10px] font-semibold text-text-2 uppercase tracking-widest mb-3 px-1">Monitors</div>
                {monitorList.map((m, i) => (
                  <div
                    key={m.name}
                    className="flex items-center justify-between px-4 py-3 rounded-lg bg-[#313742] border transition-all duration-500"
                    style={{
                      borderColor:
                        m.status === 'down'
                          ? 'rgba(239,68,68,0.3)'
                          : m.status === 'warn'
                          ? 'rgba(245,197,66,0.2)'
                          : 'rgba(255,255,255,0.05)',
                      animation: `slideInLeft 0.4s ${0.7 + i * 0.12}s ease both`,
                      opacity: 0,
                    }}
                  >
                    <div className="flex-1 min-w-0">
                      <div className="text-sm font-medium text-text mb-0.5">{m.name}</div>
                      <div className="text-xs text-text-2">
                        {m.name === 'api.myapp.com'
                          ? `Checked ${tick}s ago · ${ping1}ms`
                          : m.name === 'dashboard.myapp.com'
                          ? `Checked 1m ago · ${ping2}ms`
                          : m.status === 'down'
                          ? 'Connection refused · timeout'
                          : `Checked 1m ago · ${m.ms}`}
                      </div>
                      <div className="mt-1.5 h-0.5 rounded-full bg-white/[0.06] overflow-hidden w-32">
                        <div
                          className="h-full rounded-full transition-all duration-1000"
                          style={{
                            width: `${m.status === 'down' ? 12 : m.uptime}%`,
                            background: m.status === 'down' ? '#ef4444' : m.status === 'warn' ? '#f5c542' : '#1ddb78',
                          }}
                        />
                      </div>
                    </div>
                    <div
                      className={`inline-flex items-center gap-1.5 text-xs font-medium px-2.5 py-1 rounded-full ml-4 transition-all duration-500 ${
                        m.status === 'down'
                          ? 'bg-red-500/10 border border-red-500/30 text-red-400'
                          : m.status === 'up'
                          ? 'bg-green-bg border border-green-border text-green'
                          : 'bg-yellow-bg border border-yellow-border text-yellow'
                      }`}
                    >
                      <span
                        className={`w-1.5 h-1.5 rounded-full ${
                          m.status === 'down' ? 'bg-red-400 animate-blink' : m.status === 'up' ? 'bg-green animate-blink' : 'bg-yellow'
                        }`}
                      />
                      {m.status === 'down' ? 'Down' : m.status === 'up' ? 'Operational' : 'Warning'}
                    </div>
                  </div>
                ))}
              </div>

              {/* Right: AI panel */}
              <div className="w-full md:w-[320px] p-4 flex flex-col">
                <div className="flex items-center gap-2 mb-3 px-1">
                  <div className="w-4 h-4 rounded bg-green/10 flex items-center justify-center">
                    <svg width="9" height="9" viewBox="0 0 9 9" fill="none">
                      <path d="M1 4.5h7M4.5 1l3.5 3.5L4.5 8" stroke="#1ddb78" strokeWidth="1.3" strokeLinecap="round" strokeLinejoin="round" />
                    </svg>
                  </div>
                  <span className="text-[10px] font-semibold text-text-2 uppercase tracking-widest">AI Incident Report</span>
                  {paymentsStatus === 'down' && (
                    <span className="ml-auto flex items-center gap-1 text-[10px] text-red-400 font-medium">
                      <span className="w-1.5 h-1.5 rounded-full bg-red-400 animate-blink" />Live
                    </span>
                  )}
                </div>
                <div className="flex-1 rounded-lg bg-[#1e2128] border border-white/[0.05] p-4 font-mono text-xs text-text-2 leading-relaxed min-h-[160px]">
                  {reportChunks.length === 0 ? (
                    <span className="text-white/20">Waiting for incidents…</span>
                  ) : (
                    <>
                      {reportChunks.map((chunk, i) =>
                        chunk.text === '\n\n' ? (
                          <br key={i} />
                        ) : chunk.bold ? (
                          <span key={i} className="text-green font-semibold">{chunk.text}</span>
                        ) : (
                          <span key={i} className="text-text-2">{chunk.text}</span>
                        )
                      )}
                      <span className="inline-block w-1.5 h-3.5 bg-green ml-0.5 animate-blink align-middle" />
                    </>
                  )}
                </div>
                <div className="mt-3 text-[10px] text-white/20 text-center font-mono">plain English · no oncall engineer needed</div>
              </div>
            </div>
          )}

          {/* BLOG PANEL */}
          {!isMonitoring && (
            <div className="p-5">
              <div className="flex items-center justify-between mb-4">
                <div className="font-mono text-[11px] text-text-2">
                  CLIENT: <span style={{ color: '#a78bfa' }}>Aksara Jewellery</span> · blog.aksarajewellery.com
                </div>
                <button
                  className="flex items-center gap-1.5 text-xs font-semibold px-3 py-1.5 rounded-lg"
                  style={{ background: '#a78bfa', color: '#1a1035' }}
                >
                  ✦ Generate post
                </button>
              </div>

              <div className="grid grid-cols-3 gap-3 mb-4">
                {BLOG_POSTS.map((post, i) => (
                  <div
                    key={i}
                    className="rounded-xl border border-white/[0.06] bg-[#313742] overflow-hidden"
                    style={{ animation: `slideInLeft 0.4s ${0.1 + i * 0.12}s ease both`, opacity: 0 }}
                  >
                    <div
                      className="h-16 flex items-center justify-center font-mono text-[10px]"
                      style={{
                        background: 'linear-gradient(135deg, #1a1a2e, #16213e)',
                        color: post.status === 'writing' ? 'rgba(167,139,250,0.5)' : 'rgba(167,139,250,0.3)',
                      }}
                    >
                      {post.status === 'writing' ? 'generating…' : 'cover · pexels'}
                    </div>
                    <div className="p-2.5">
                      <span
                        className="text-[9px] font-bold uppercase tracking-widest px-1.5 py-0.5 rounded mb-1.5 inline-block"
                        style={{ background: 'rgba(167,139,250,0.12)', color: '#a78bfa' }}
                      >
                        {post.tag}
                      </span>
                      <div className="text-[11px] font-semibold text-text leading-tight mb-2">{post.title}</div>
                      <div className="flex items-center justify-between">
                        <span className="text-[10px] text-text-2 font-mono">{post.date}</span>
                        {post.status === 'live' ? (
                          <span
                            className="text-[9px] font-bold px-1.5 py-0.5 rounded flex items-center gap-1"
                            style={{ background: 'rgba(74,222,128,0.1)', color: '#4ade80' }}
                          >
                            <span className="w-1 h-1 rounded-full bg-[#4ade80]" />Live
                          </span>
                        ) : (
                          <span
                            className="text-[9px] font-bold px-1.5 py-0.5 rounded flex items-center gap-1"
                            style={{ background: 'rgba(167,139,250,0.1)', color: '#a78bfa' }}
                          >
                            <span
                              className="w-1 h-1 rounded-full"
                              style={{ background: '#a78bfa', opacity: genDot ? 1 : 0.2, transition: 'opacity 0.3s' }}
                            />
                            Writing…
                          </span>
                        )}
                      </div>
                    </div>
                  </div>
                ))}
              </div>

              <div
                className="rounded-lg px-4 py-3 font-mono text-[11px]"
                style={{ background: 'rgba(167,139,250,0.06)', border: '1px solid rgba(167,139,250,0.15)', color: 'rgba(255,255,255,0.4)' }}
              >
                <span style={{ color: '#a78bfa' }}>blog.aksarajewellery.com</span> · 3 posts published · 2,140 organic impressions this month ·{' '}
                <span style={{ color: '#4ade80' }}>↑ 34% vs last month</span>
              </div>
            </div>
          )}
        </div>
      </div>

      <style>{`
        @keyframes gridDrift { from { background-position: 0 0; } to { background-position: 48px 48px; } }
        @keyframes breathe { 0%,100%{transform:translateX(-50%) scale(1);opacity:0.6} 50%{transform:translateX(-50%) scale(1.3);opacity:1} }
        @keyframes textPulse { 0%,100%{text-shadow:0 0 20px rgba(29,219,120,0.2)} 50%{text-shadow:0 0 40px rgba(29,219,120,0.5)} }
        @keyframes scanBeam { 0%{left:-80px} 100%{left:110%} }
        @keyframes slideInLeft { from{opacity:0;transform:translateX(-12px)} to{opacity:1;transform:translateX(0)} }
        @keyframes fadeUp { from{opacity:0;transform:translateY(16px)} to{opacity:1;transform:translateY(0)} }
      `}</style>
    </section>
  );
}
