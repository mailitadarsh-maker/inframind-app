'use client';

import { useEffect, useRef, useState } from 'react';
import Link from 'next/link';

const monitoringFeatures = [
  { icon: '🛡', text: 'Uptime, API & SSL monitoring — checks every 30 seconds' },
  { icon: '🧠', text: 'AI explains what broke & gives you a step-by-step fix' },
  { icon: '📄', text: 'Public status page to share live health with customers' },
  { icon: '⚡', text: 'Email alerts the moment something goes down or recovers' },
];

const blogFeatures = [
  { icon: '🌐', text: 'Client gets their own blog at blog.theirdomain.com' },
  { icon: '✍️', text: 'AI writes the post — you publish it in one click' },
  { icon: '🚀', text: 'Goes live instantly — no code, no deployment' },
  { icon: '🔍', text: 'SEO-ready: meta tags, Open Graph, canonical URLs auto-added' },
];

export default function BlogServiceStrip() {
  const ref = useRef<HTMLDivElement>(null);
  const [visible, setVisible] = useState(false);

  useEffect(() => {
    const obs = new IntersectionObserver(
      ([e]) => { if (e.isIntersecting) { setVisible(true); obs.disconnect(); } },
      { threshold: 0.08 }
    );
    if (ref.current) obs.observe(ref.current);
    return () => obs.disconnect();
  }, []);

  return (
    <section
      ref={ref}
      style={{
        background: '#1e2128',
        borderTop: '1px solid rgba(255,255,255,0.05)',
        borderBottom: '1px solid rgba(255,255,255,0.05)',
        padding: '80px 40px',
        position: 'relative',
        overflow: 'hidden',
      }}
    >
      {/* Background glows */}
      <div style={{ position: 'absolute', top: '-60px', right: '-60px', width: 400, height: 400, borderRadius: '50%', background: 'radial-gradient(circle, rgba(167,139,250,0.05) 0%, transparent 70%)', pointerEvents: 'none' }} />
      <div style={{ position: 'absolute', bottom: '-40px', left: '10%', width: 300, height: 300, borderRadius: '50%', background: 'radial-gradient(circle, rgba(29,219,120,0.04) 0%, transparent 70%)', pointerEvents: 'none' }} />

      <div style={{ maxWidth: 1100, margin: '0 auto' }}>
        {/* Section header */}
        <div
          style={{
            textAlign: 'center',
            marginBottom: 56,
            opacity: visible ? 1 : 0,
            transform: visible ? 'translateY(0)' : 'translateY(24px)',
            transition: 'opacity 0.7s, transform 0.7s',
          }}
        >
          <div style={{ display: 'flex', alignItems: 'center', justifyContent: 'center', gap: 10, marginBottom: 18 }}>
            <span style={{ display: 'inline-flex', alignItems: 'center', gap: 6, fontSize: 11, fontWeight: 700, letterSpacing: '0.1em', textTransform: 'uppercase', color: '#1ddb78', background: 'rgba(29,219,120,0.08)', border: '1px solid rgba(29,219,120,0.2)', borderRadius: 99, padding: '4px 12px' }}>
              <span style={{ width: 5, height: 5, borderRadius: '50%', background: '#1ddb78', display: 'inline-block' }} />
              App monitoring
            </span>
            <span style={{ fontSize: 12, color: 'rgba(255,255,255,0.2)', fontWeight: 700 }}>+</span>
            <span style={{ display: 'inline-flex', alignItems: 'center', gap: 6, fontSize: 11, fontWeight: 700, letterSpacing: '0.1em', textTransform: 'uppercase', color: '#a78bfa', background: 'rgba(167,139,250,0.08)', border: '1px solid rgba(167,139,250,0.2)', borderRadius: 99, padding: '4px 12px' }}>
              <span style={{ width: 5, height: 5, borderRadius: '50%', background: '#a78bfa', display: 'inline-block' }} />
              Blog as a service
            </span>
          </div>
          <h2 style={{ fontSize: 'clamp(26px, 4vw, 40px)', fontWeight: 800, color: '#fff', lineHeight: 1.15, letterSpacing: '-0.03em', margin: '0 0 12px' }}>
            One platform. Two powerful tools.
          </h2>
          <p style={{ fontSize: 15, color: 'rgba(255,255,255,0.4)', maxWidth: 480, margin: '0 auto', lineHeight: 1.7 }}>
            Keep your clients' apps online 24/7 and grow their organic traffic — all managed from your InfraMind dashboard.
          </p>
        </div>

        {/* Two-column product cards */}
        <div
          style={{
            display: 'grid',
            gridTemplateColumns: 'repeat(auto-fit, minmax(300px, 1fr))',
            gap: 20,
            opacity: visible ? 1 : 0,
            transform: visible ? 'translateY(0)' : 'translateY(28px)',
            transition: 'opacity 0.7s 0.15s, transform 0.7s 0.15s',
          }}
        >
          {/* Monitoring card */}
          <div style={{ borderRadius: 16, border: '1px solid rgba(29,219,120,0.2)', background: 'linear-gradient(160deg, #0d2318 0%, #1e2128 60%)', padding: '32px 28px', position: 'relative', overflow: 'hidden' }}>
            <div style={{ position: 'absolute', top: -30, right: -30, width: 160, height: 160, borderRadius: '50%', background: 'radial-gradient(circle, rgba(29,219,120,0.08) 0%, transparent 70%)', pointerEvents: 'none' }} />
            <div style={{ display: 'inline-flex', alignItems: 'center', gap: 6, fontSize: 10, fontWeight: 700, letterSpacing: '0.12em', textTransform: 'uppercase', color: '#1ddb78', background: 'rgba(29,219,120,0.1)', border: '1px solid rgba(29,219,120,0.2)', borderRadius: 6, padding: '3px 10px', marginBottom: 18 }}>
              Product 1
            </div>
            <h3 style={{ fontSize: 22, fontWeight: 800, color: '#fff', lineHeight: 1.2, letterSpacing: '-0.02em', margin: '0 0 10px' }}>
              App Monitoring
            </h3>
            <p style={{ fontSize: 13, color: 'rgba(255,255,255,0.4)', lineHeight: 1.7, margin: '0 0 24px' }}>
              Know the moment something breaks — before your customers do.
            </p>
            <div style={{ display: 'flex', flexDirection: 'column', gap: 10, marginBottom: 28 }}>
              {monitoringFeatures.map((f, i) => (
                <div key={i} style={{ display: 'flex', alignItems: 'flex-start', gap: 10 }}>
                  <span style={{ fontSize: 14, flexShrink: 0, marginTop: 1 }}>{f.icon}</span>
                  <span style={{ fontSize: 13, color: 'rgba(255,255,255,0.55)', lineHeight: 1.6 }}>{f.text}</span>
                </div>
              ))}
            </div>
            <Link
              href="/signup"
              style={{ display: 'inline-flex', alignItems: 'center', gap: 8, padding: '10px 22px', borderRadius: 9, background: 'rgba(29,219,120,0.12)', border: '1px solid rgba(29,219,120,0.3)', color: '#1ddb78', fontSize: 13, fontWeight: 700, textDecoration: 'none' }}
            >
              Start monitoring free →
            </Link>
          </div>

          {/* Blog card */}
          <div style={{ borderRadius: 16, border: '1px solid rgba(167,139,250,0.2)', background: 'linear-gradient(160deg, #110d25 0%, #1e2128 60%)', padding: '32px 28px', position: 'relative', overflow: 'hidden' }}>
            <div style={{ position: 'absolute', top: -30, right: -30, width: 160, height: 160, borderRadius: '50%', background: 'radial-gradient(circle, rgba(167,139,250,0.08) 0%, transparent 70%)', pointerEvents: 'none' }} />
            <div style={{ display: 'inline-flex', alignItems: 'center', gap: 6, fontSize: 10, fontWeight: 700, letterSpacing: '0.12em', textTransform: 'uppercase', color: '#a78bfa', background: 'rgba(167,139,250,0.1)', border: '1px solid rgba(167,139,250,0.2)', borderRadius: 6, padding: '3px 10px', marginBottom: 18 }}>
              Product 2
            </div>
            <h3 style={{ fontSize: 22, fontWeight: 800, color: '#fff', lineHeight: 1.2, letterSpacing: '-0.02em', margin: '0 0 10px' }}>
              Blog as a Service
            </h3>
            <p style={{ fontSize: 13, color: 'rgba(255,255,255,0.4)', lineHeight: 1.7, margin: '0 0 24px' }}>
              Fresh SEO content for every client, published automatically.
            </p>
            <div style={{ display: 'flex', flexDirection: 'column', gap: 10, marginBottom: 28 }}>
              {blogFeatures.map((f, i) => (
                <div key={i} style={{ display: 'flex', alignItems: 'flex-start', gap: 10 }}>
                  <span style={{ fontSize: 14, flexShrink: 0, marginTop: 1 }}>{f.icon}</span>
                  <span style={{ fontSize: 13, color: 'rgba(255,255,255,0.55)', lineHeight: 1.6 }}>{f.text}</span>
                </div>
              ))}
            </div>
            <Link
              href="/blog-service"
              style={{ display: 'inline-flex', alignItems: 'center', gap: 8, padding: '10px 22px', borderRadius: 9, background: '#a78bfa', color: '#1a1035', fontSize: 13, fontWeight: 700, textDecoration: 'none' }}
            >
              See how it works →
            </Link>
          </div>
        </div>
      </div>
    </section>
  );
}
